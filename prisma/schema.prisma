// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

datasource db {
  provider = "postgresql"
  
  
}

generator client {
  provider   = "prisma-client-js"
  
}


// ====================== ENUMS ======================
enum RoleUtilisateur {
  ADMIN
  SUPERVISEUR
  AUDITEUR
}

enum TypeActif {
  SERVEUR
  WORKSTATION
  FIREWALL
  ROUTER
  APPLICATION
  BDD
  CLOUD
  AUTRE
}

enum NiveauCriticite {
  BAS
  MOYEN
  ELEVE
  CRITIQUE
}

enum Severite {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum StatutVulnerabilite {
  OUVERTE
  EN_COURS
  CORRIGEE
  IGNORE
  RISQUE_ACCEPTE
  VERIFIEE
}

enum StatutScan {
  PLANIFIE
  EN_COURS
  TERMINE
  ANNULE
  ECHEC
}

enum TypeScan {
  VULNERABILITE
  COMPLIANCE
  PENETRATION
  CONFIGURATION
}

enum OutilScan {
  NESSUS
  OPENVAS
  QUALYS
  BURP_SUITE
  TRIVY
  ZAP
  MANUAL
  GRYPE
  NUCLEI
}

enum FormatRapport {
  PDF
  JSON
  CSV
  HTML
  MARKDOWN
}

enum Priorite {
  BASSE
  MOYENNE
  HAUTE
  CRITIQUE
}

enum StatutPlan {
  A_FAIRE
  EN_COURS
  TERMINE
  EN_RETARD
  ANNULE
  VERIFIE
}

enum StatutConformite {
  CONFORME
  NON_CONFORME
  PARTIELLEMENT
  NON_EVALUE
}

// ====================== AUDIT TRAIL ENUMS ======================
enum TypeAction {
  CONNEXION
  DECONNEXION
  CREATION
  MODIFICATION
  SUPPRESSION
  LECTURE
  EXPORT
  SCAN
  ASSIGNATION
  VALIDATION
}

enum EntiteCible {
  UTILISATEUR
  ACTIF
  SCAN
  VULNERABILITE
  PLAN_CORRECTION
  RAPPORT
  CONTROLE_CONFORMITE
}

model Utilisateur {
  id                      String    @id @default(uuid()) @db.Uuid
  nom                     String
  prenom                  String
  email                   String    @unique
  motDePasseHashe         String
  role                    RoleUtilisateur
  actif                   Boolean   @default(true)
  deletedAt               DateTime?

  scansLancees            Scan[]                    @relation("ScanLancePar")
  rapportsGenere          RapportAudit[]            @relation("RapportGenerePar")
  vulnerabilitesAssignees Vulnerabilite[]           @relation("VulnAssigneA")
  plansAssignes           PlanCorrection[]          @relation("PlanAssigneA")
  historiquesVulnerabilite HistoriqueVulnerabilite[] @relation("HistoriqueModifiePar")
  auditLogs               AuditLog[]                @relation("AuditUtilisateur")

  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt

  @@map("utilisateur")
}

model Actif {
  id          String    @id @default(uuid()) @db.Uuid
  nom         String
  adresseIP   String?
  hostname    String?
  type        TypeActif
  criticite   NiveauCriticite
  localisation String?
  dernierScan DateTime?
  deletedAt   DateTime?

  scans       Scan[]         @relation("ScanSurActif")
  rapports    RapportAudit[] @relation("RapportActif")

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([adresseIP])
  @@index([criticite])
  @@map("actifs")
}

model Scan {
  id String @id @default(uuid()) @db.Uuid
  idActif String @db.Uuid
  lancerPar String @db.Uuid
  type TypeScan
  outil OutilScan
  statut StatutScan @default(PLANIFIE)
  debut DateTime?
  fin DateTime?
  duree Int?
  resultatBrut Json?
  metadata Json?
  erreur String?
  
  // === AJOUTS ===
  cible String?           // ex: "192.168.10.10", "web-app.local", etc.
  
  actif Actif @relation("ScanSurActif", fields: [idActif], references: [id], onDelete: Cascade)
  utilisateur Utilisateur @relation("ScanLancePar", fields: [lancerPar], references: [id])
  vulnerabilites Vulnerabilite[] @relation("DetecteeParScan")
  controlesEvalues ControlScan[] @relation("ScanControles")
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@map("scans")
}

model Vulnerabilite {
  id String @id @default(uuid()) @db.Uuid
  idScan String @db.Uuid
  cveId String?
  titre String
  description String?
  severite Severite
  scoreCVSS Float?
  cvssVersion String?
  epssScore Float?
  vecteurCVSS String?
  statut StatutVulnerabilite @default(OUVERTE)
  assigneA String? @db.Uuid
  preuve String?
  impact String?
  recommandation String?
  
  // === AJOUTS ===
  risqueRelatif Float?     // Pour le calcul de risque relatif
  tags TagVulnerabilite[]  // Relation many-to-many

  scan Scan @relation("DetecteeParScan", fields: [idScan], references: [id], onDelete: Cascade)
  assigne Utilisateur? @relation("VulnAssigneA", fields: [assigneA], references: [id])
  plan PlanCorrection?
  historiques HistoriqueVulnerabilite[] @relation("HistoriqueVulnerabilite")
  
  dateDecouverte DateTime @default(now())
  dateCorrection DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
  @@map("vulnerabilites")
}

model PlanCorrection {
  id               String    @id @default(uuid()) @db.Uuid
  idVulnerabilite  String    @db.Uuid @unique           // ← Corrigé
  assigneA         String    @db.Uuid                    // ← Corrigé
  priorite         Priorite
  dateEcheance     DateTime
  statut           StatutPlan          @default(A_FAIRE)
  commentaire      String?
  dateResolution   DateTime?

  vulnerabilite    Vulnerabilite       @relation(fields: [idVulnerabilite], references: [id], onDelete: Cascade)
  assigne          Utilisateur         @relation("PlanAssigneA", fields: [assigneA], references: [id])

  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@map("plans_correction")
}

model HistoriqueVulnerabilite {
  id String @id @default(uuid()) @db.Uuid
  idVulnerabilite String @db.Uuid
  ancienStatut StatutVulnerabilite
  nouveauStatut StatutVulnerabilite
  commentaire String?
  modifiePar String @db.Uuid
  dateModification DateTime @default(now())
  
  // === AJOUT ===
  createdAt DateTime @default(now())
  
  vulnerabilite Vulnerabilite @relation("HistoriqueVulnerabilite", fields: [idVulnerabilite], references: [id], onDelete: Cascade)
  utilisateur Utilisateur @relation("HistoriqueModifiePar", fields: [modifiePar], references: [id])
  @@map("historique_vulnerabilites")
}

model RapportAudit {
  id          String    @id @default(uuid()) @db.Uuid
  generePar   String    @db.Uuid                              // ← Corrigé
  idActif     String    @db.Uuid                              // ← Corrigé
  titre       String
  description String?
  format      FormatRapport
  urlFichier  String?
  genereLe    DateTime  @default(now())

  utilisateur Utilisateur @relation("RapportGenerePar", fields: [generePar], references: [id])
  actif       Actif       @relation("RapportActif", fields: [idActif], references: [id])

  createdAt   DateTime    @default(now())

  @@map("rapports_audit")
}

model ControlConformite {
  id          String    @id @default(uuid()) @db.Uuid
  referentiel String
  code        String
  description String
  statut      StatutConformite @default(NON_EVALUE)

  scans       ControlScan[]

  @@unique([referentiel, code])
  @@map("controles_conformite")
}

model ControlScan {
  id          String    @id @default(uuid()) @db.Uuid
  idScan      String    @db.Uuid                            // ← Corrigé
  idControle  String    @db.Uuid                            // ← Corrigé
  statut      StatutConformite
  commentaire String?
  preuve      String?

  scan        Scan             @relation("ScanControles", fields: [idScan], references: [id], onDelete: Cascade)
  controle    ControlConformite @relation(fields: [idControle], references: [id])

  @@map("control_scan")
}

model AuditLog {
  id          String    @id @default(uuid()) @db.Uuid
  idUtilisateur String?   @db.Uuid                          // ← Corrigé
  action      TypeAction
  entite      EntiteCible
  idEntite    String?
  details     Json?
  ipAdresse   String?
  userAgent   String?
  dateAction  DateTime     @default(now())

  utilisateur Utilisateur? @relation("AuditUtilisateur", fields: [idUtilisateur], references: [id], onDelete: SetNull)

  @@index([idUtilisateur])
  @@index([action])
  @@index([entite])
  @@index([dateAction])
  @@map("audit_logs")
}

model Tag {
  id String @id @default(uuid()) @db.Uuid
  nom String @unique
  couleur String? 
  vulnerabilites TagVulnerabilite[]
  createdAt DateTime @default(now())
  @@map("tags")
}

model TagVulnerabilite {
  id String @id @default(uuid()) @db.Uuid
  vulnerabiliteId String @db.Uuid
  tagId String @db.Uuid
  vulnerabilite Vulnerabilite @relation(fields: [vulnerabiliteId], references: [id], onDelete: Cascade)
  tag Tag @relation(fields: [tagId], references: [id], onDelete: Cascade)
  @@unique([vulnerabiliteId, tagId])
  @@map("tag_vulnerabilite")
}