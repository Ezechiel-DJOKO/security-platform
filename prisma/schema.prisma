generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Utilisateur {
  id                       String                    @id @default(uuid()) @db.Uuid
  nom                      String
  prenom                   String
  email                    String                    @unique
  role                     RoleUtilisateur
  actif                    Boolean                   @default(true)
  deletedAt                DateTime?
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  motDePasseHash           String
  auditLogs                AuditLog[]                @relation("AuditUtilisateur")
  historiquesVulnerabilite HistoriqueVulnerabilite[] @relation("HistoriqueModifiePar")
  plansAssignes            PlanCorrection[]          @relation("PlanAssigneA")
  plansCrees               PlanCorrection[]          @relation("PlanCreatedBy")
  rapportsGenere           RapportAudit[]            @relation("RapportGenerePar")
  scansLancees             Scan[]                    @relation("ScanLancePar")
  vulnerabilitesAssignees  Vulnerabilite[]           @relation("VulnAssigneA")

  @@map("utilisateur")
}

model Actif {
  id           String          @id @default(uuid()) @db.Uuid
  nom          String
  adresseIP    String?
  hostname     String?
  type         TypeActif
  criticite    NiveauCriticite?
  localisation String?
  dernierScan  DateTime?
  deletedAt    DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  rapports     RapportAudit[]  @relation("RapportActif")
  scans        Scan[]          @relation("ScanSurActif")
  vulnerabilites Vulnerabilite[] @relation("VulnSurActif")

  @@index([adresseIP])
  @@index([criticite])
  @@index([type])
  @@map("actifs")
}

model Scan {
  id               String          @id @default(uuid()) @db.Uuid
  idActif          String          @db.Uuid
  lancerPar        String          @db.Uuid
  type             TypeScan
  outil            OutilScan
  statut           StatutScan      @default(PLANIFIE)
  debut            DateTime?
  fin              DateTime?
  duree            Int?
  resultatBrut     Json?
  metadata         Json?
  erreur           String?
  cible            String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  resultatOpenvas  Json?
  controlesEvalues ControlScan[]   @relation("ScanControles")
  actif            Actif           @relation("ScanSurActif", fields: [idActif], references: [id], onDelete: Cascade)
  utilisateur      Utilisateur     @relation("ScanLancePar", fields: [lancerPar], references: [id])
  vulnerabilites   Vulnerabilite[] @relation("DetecteeParScan")

  @@map("scans")
}

model Vulnerabilite {
  id                String                    @id @default(uuid()) @db.Uuid
  idScan            String                    @db.Uuid
  idActif           String?                   @db.Uuid
  cveId             String?
  titre             String
  description       String?
  severite          Severite
  scoreCVSS         Float?
  cvssVersion       String?
  epssScore         Float?
  vecteurCVSS       String?
  statut            StatutVulnerabilite       @default(OUVERTE)
  assigneA          String?                   @db.Uuid
  preuve            String?
  impact            String?
  recommandation    String?
  risqueRelatif     Float?
  dateDecouverte    DateTime                  @default(now())
  dateCorrection    DateTime?
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt
  deletedAt         DateTime?
  endpoint          String?
  methodeHttp       String?
  payload           String?
  typeVulnerabilite TypeVulnerabilite?
  urlCible          String?
  historiques       HistoriqueVulnerabilite[] @relation("HistoriqueVulnerabilite")
  plan              PlanCorrection[]
  tags              TagVulnerabilite[]
  controles         VulnerabiliteControl[]
  assigne           Utilisateur?              @relation("VulnAssigneA", fields: [assigneA], references: [id])
  scan              Scan                      @relation("DetecteeParScan", fields: [idScan], references: [id], onDelete: Cascade)
  actif             Actif?                    @relation("VulnSurActif", fields: [idActif], references: [id])

  @@index([statut])
  @@index([severite])
  @@index([assigneA])
  @@map("vulnerabilites")
}

model PlanCorrection {
  id              String        @id @default(uuid()) @db.Uuid
  idVulnerabilite String        @db.Uuid
  assigneA        String?       @db.Uuid
  priorite        Priorite
  dateEcheance    DateTime
  statut          StatutPlan    @default(A_FAIRE)
  commentaire     String?
  dateResolution  DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  createdBy       String?       @db.Uuid
  assigne         Utilisateur?  @relation("PlanAssigneA", fields: [assigneA], references: [id])
  createur        Utilisateur?  @relation("PlanCreatedBy", fields: [createdBy], references: [id])
  vulnerabilite   Vulnerabilite @relation(fields: [idVulnerabilite], references: [id], onDelete: Cascade)

  @@map("plans_correction")
}

model HistoriqueVulnerabilite {
  id               String              @id @default(uuid()) @db.Uuid
  idVulnerabilite  String              @db.Uuid
  ancienStatut     StatutVulnerabilite
  nouveauStatut    StatutVulnerabilite
  commentaire      String?
  modifiePar       String              @db.Uuid
  dateModification DateTime            @default(now())
  createdAt        DateTime            @default(now())
  vulnerabilite    Vulnerabilite       @relation("HistoriqueVulnerabilite", fields: [idVulnerabilite], references: [id], onDelete: Cascade)
  utilisateur      Utilisateur         @relation("HistoriqueModifiePar", fields: [modifiePar], references: [id])

  @@map("historique_vulnerabilites")
}

model RapportAudit {
  id          String        @id @default(uuid()) @db.Uuid
  generePar   String        @db.Uuid
  idActif     String        @db.Uuid
  titre       String
  description String?
  format      FormatRapport
  urlFichier  String?
  genereLe    DateTime      @default(now())
  createdAt   DateTime      @default(now())
  utilisateur Utilisateur   @relation("RapportGenerePar", fields: [generePar], references: [id])
  actif       Actif         @relation("RapportActif", fields: [idActif], references: [id])

  @@map("rapports_audit")
}

model ControlConformite {
  id             String                 @id @default(uuid()) @db.Uuid
  referentiel    String                 @default("ISO27001")
  code           String
  nom            String
  description    String
  domaine        String?
  theme          String?
  statut         StatutConformite       @default(NON_EVALUE)
  ponderation    Int                    @default(10)
  scans          ControlScan[]
  vulnerabilites VulnerabiliteControl[]

  @@unique([referentiel, code])
  @@index([domaine])
  @@index([theme])
  @@map("controles_conformite")
}

model VulnerabiliteControl {
  id               String            @id @default(uuid()) @db.Uuid
  vulnerabiliteId  String            @db.Uuid
  controleId       String            @db.Uuid
  niveauPertinence Int               @default(80)
  justification    String?
  sourceMapping    String            @default("AUTO")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  controle         ControlConformite @relation(fields: [controleId], references: [id], onDelete: Cascade)
  vulnerabilite    Vulnerabilite     @relation(fields: [vulnerabiliteId], references: [id], onDelete: Cascade)

  @@unique([vulnerabiliteId, controleId])
  @@map("vulnerabilite_control")
}

model ControlScan {
  id          String            @id @default(uuid()) @db.Uuid
  idScan      String            @db.Uuid
  idControle  String            @db.Uuid
  statut      StatutConformite
  commentaire String?
  preuve      String?
  controle    ControlConformite @relation(fields: [idControle], references: [id])
  scan        Scan              @relation("ScanControles", fields: [idScan], references: [id], onDelete: Cascade)

  @@map("control_scan")
}

model AuditLog {
  id            String       @id @default(uuid()) @db.Uuid
  idUtilisateur String?      @db.Uuid
  action        TypeAction
  entite        EntiteCible
  idEntite      String?
  details       Json?
  ipAdresse     String?
  userAgent     String?
  dateAction    DateTime     @default(now())
  utilisateur   Utilisateur? @relation("AuditUtilisateur", fields: [idUtilisateur], references: [id])

  @@index([idUtilisateur])
  @@index([action])
  @@index([entite])
  @@index([dateAction])
  @@map("audit_logs")
}

model Tag {
  id             String             @id @default(uuid()) @db.Uuid
  nom            String             @unique
  couleur        String?
  createdAt      DateTime           @default(now())
  vulnerabilites TagVulnerabilite[]

  @@map("tags")
}

model TagVulnerabilite {
  id              String        @id @default(uuid()) @db.Uuid
  vulnerabiliteId String        @db.Uuid
  tagId           String        @db.Uuid
  tag             Tag           @relation(fields: [tagId], references: [id], onDelete: Cascade)
  vulnerabilite   Vulnerabilite @relation(fields: [vulnerabiliteId], references: [id], onDelete: Cascade)

  @@unique([vulnerabiliteId, tagId])
  @@map("tag_vulnerabilite")
}

model KpiHistory {
  id                          String   @id @default(uuid()) @db.Uuid
  date                        DateTime @unique @default(now())
  pourcentageCritiquesResolus Float    @default(0)
  delaiMoyenCorrection        Float    @default(0)
  scoreISO27001               Int      @default(0)
  totalVulnerabilites         Int      @default(0)
  vulnsCritiques              Int      @default(0)
  vulnsCorrigees              Int      @default(0)
  createdAt                   DateTime @default(now())

  @@map("kpi_history")
}

enum RoleUtilisateur {
  ADMIN
  SUPERVISEUR
  AUDITEUR
  TECHNICIEN
}

enum TypeActif {
  SERVEUR
  WORKSTATION
  FIREWALL
  ROUTER
  APPLICATION
  BDD
  CLOUD
  AUTRE
}

enum NiveauCriticite {
  BAS
  MOYEN
  ELEVE
  CRITIQUE
}

enum Severite {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum StatutVulnerabilite {
  OUVERTE
  EN_COURS
  CORRIGEE
  IGNORE
  RISQUE_ACCEPTE
  VERIFIEE
}

enum StatutScan {
  PLANIFIE
  EN_COURS
  TERMINE
  ANNULE
  ECHEC
}

enum TypeScan {
  VULNERABILITE
  COMPLIANCE
  PENETRATION
  CONFIGURATION
}

enum OutilScan {
  NESSUS
  OPENVAS
  QUALYS
  BURP_SUITE
  TRIVY
  ZAP
  MANUAL
  GRYPE
  NUCLEI
}

enum FormatRapport {
  PDF
  JSON
  CSV
  HTML
  MARKDOWN
}

enum Priorite {
  BASSE
  MOYENNE
  HAUTE
  CRITIQUE
}

enum StatutPlan {
  A_FAIRE
  EN_COURS
  TERMINE
  EN_RETARD
  ANNULE
  VERIFIE
  REJETEE
}

enum StatutConformite {
  CONFORME
  NON_CONFORME
  PARTIELLEMENT
  NON_EVALUE
  NON_APPLICABLE
}

enum TypeAction {
  CONNEXION
  DECONNEXION
  CREATION
  MODIFICATION
  SUPPRESSION
  LECTURE
  EXPORT
  SCAN
  ASSIGNATION
  VALIDATION
  SCAN_COMPLETED
  REJET
}

enum EntiteCible {
  UTILISATEUR
  ACTIF
  SCAN
  VULNERABILITE
  PLAN_CORRECTION
  RAPPORT
  CONTROLE_CONFORMITE
}

enum TypeVulnerabilite {
  NETWORK
  WEB_APP
  API
  CLOUD
  CONTAINER
  DEPENDENCY
  CONFIG
  OTHER
}
